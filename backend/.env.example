# Copy this file to .env and change these values before deploying.

# Database URL: Supports PostgreSQL or SQLite
# Example PostgreSQL: postgresql://postgres:postgres@localhost:5432/edubridge
# Example SQLite: sqlite:///./edubridge.db
DATABASE_URL=sqlite:///./edubridge.db

# Admin login for the /admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Used to sign admin and user login sessions. Set this to a long random string.
JWT_SECRET=change-this-to-a-long-random-secret

# Comma separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
